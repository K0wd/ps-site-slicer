BASE_URL=https://testserver.betacom.com/
TEST_USERNAME=Bandeleonk
TEST_PASSWORD=test1234

# Override the Claude model used for every script-based CLI call from
# TestGenerator (Step 4/5/6/7/etc.). Defaults to claude-sonnet-4-6 — Sonnet
# is sufficient for formulaic templating (test plans, KB postings) and shifts
# spend off Opus-only buckets onto the Sonnet-only weekly cap. Override with
# claude-opus-4-7 if a step needs Opus-grade reasoning consistently.
# TESTGEN_CLAUDE_MODEL=claude-sonnet-4-6

# Step 4 — multi-repo commit lookup via GitLab API
# Personal access token with `read_api` + `read_repository` scopes.
# When set, Step 4 queries the GitLab API across the whole group (no local clones
# needed) to find every commit referencing the ticket key. Falls back to local
# git scanning if unset or if the API call fails.
# Create at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# Optional GitLab overrides (defaults shown).
# GITLAB_BASE_URL=https://gitlab.com
# GITLAB_GROUP_PATH=powerslice-software-development

# Optional override — comma-separated absolute paths to local SM repo clones.
# Only used as fallback when GITLAB_TOKEN is unset. If unset, Step 4
# auto-discovers sibling git repos beside ps-site-slicer.
# SM_REPO_DIRS=/Users/you/Projects/.../sm-spa,/Users/you/Projects/.../sm-pwa

# Eng05 Send Test Emails — Gmail App Password on smtestimap@gmail.com
# To send for real: enable 2FA on smtestimap@gmail.com, generate an App Password
# at https://myaccount.google.com/apppasswords, paste below, set EMAIL_DRY_RUN=false.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=smtestimap@gmail.com
SMTP_PASS=
EMAIL_FROM=smtestimap@gmail.com
EMAIL_TO=smtestimap@gmail.com
EMAIL_DRY_RUN=true
