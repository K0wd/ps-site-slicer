  "fields": {
    "summary": "PWA - Clock Simple Module",
    "description": {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "📝 User Story: Convert Clock Simple Module to SiteManager PWA"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "As A: SiteManager PWA user"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "I Want To: Use the Clock Simple module for timesheet entry and management within the SiteManager PWA (Next.js)"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "So That: I can perform all timesheet-related actions (entry, period management, work order selection, etc.) in a web environment, consistent with the mobile app experience."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Acceptance Criteria (ACs)"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC1: QA can log in to the PWA at "
            },
            {
              "type": "text",
              "text": "https://testserver.betacom.com/testpwa",
              "marks": [
                {
                  "type": "link",
                  "attrs": {
                    "href": "https://testserver.betacom.com/testpwa"
                  }
                }
              ]
            },
            {
              "type": "text",
              "text": " using test server credentials."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC2: Selecting a date loads existing timesheet periods under \"Current Period(s)\" (read-only)."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC3: User can add, edit, and delete new periods for the selected date."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC4: Work Order search and selection, truck selection dropdown, and lunch duration selection are available."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC5: Tech Response, Comments, On-Call, Personal, Property, Damage, and Near Miss fields are present and functional."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC6: User can save and approve timesheets; saving updates the database correctly."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC7: Salary users are restricted from adding periods."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC8: Approved timesheets cannot be modified."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Scenario Example"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "Input: User logs in, selects a date, adds a new period, selects a work order, enters lunch duration, fills out required fields, and saves the timesheet."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "Expected Output: New period appears under the selected date, data is saved to the database, and all restrictions (salary user, approved timesheet) are enforced."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Original Description:"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "Convert the Clock Simple module from the React Native mobile app to the SiteManager PWA (Next.js)."
            },
            {
              "type": "hardBreak"
            },
