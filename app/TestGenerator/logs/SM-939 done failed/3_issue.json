        },
        {
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "As a "
            },
            {
              "type": "text",
              "text": "User",
              "marks": [
                {
                  "type": "strong"
                }
              ]
            },
            {
              "type": "text",
              "text": " interacting with the Quoting, Purchasing, and Vendor Admin modules, I want the "
            },
            {
              "type": "text",
              "text": "toolbar button order in all AG Grids to be consistent",
              "marks": [
                {
                  "type": "strong"
                }
              ]
            },
            {
              "type": "text",
              "text": " so that I can "
            },
            {
              "type": "text",
              "text": "quickly locate and use common actions",
              "marks": [
                {
                  "type": "strong"
                }
              ]
            },
            {
              "type": "text",
              "text": " regardless of the module I am in."
            }
          ]
        },
