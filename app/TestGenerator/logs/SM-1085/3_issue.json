{
  "key": "SM-1085",
  "fields": {
    "summary": "PWA - Expense Module",
    "description": {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "📝 User Story: Expense Module Migration to SiteManager PWA"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "As A: SiteManager user"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "I Want To: Access and manage expenses through the SiteManager PWA (Next.js)"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "So That: I can perform all expense-related tasks from any device without relying on the React Native mobile app."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Acceptance Criteria (ACs)"
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC1: Users can search expenses by specifying a date range."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC2: Users can view a list of expenses, each displayed as a card item."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC3: Users can view detailed information for each expense, including amount, category, and approval status."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC4: Users can create new expenses and edit existing ones using a form."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC5: Expense categories and types are dynamically loaded from metadata."
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "AC6: Users can calculate mileage within the expense module."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Scenario Example"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Searching Expenses"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Input: User selects a date range (e.g., 2026-03-01 to 2026-03-15) and submits search."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Output: Expense list updates to show only expenses within the selected date range."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Creating an Expense"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Input: User fills out the create expense form (amount, category, type, mileage) and submits."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Output: New expense appears in the expense list with correct details and calculated mileage."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Original Description:"
